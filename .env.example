# ─── Required ────────────────────────────────────────────────────────────────
# Secret to protect your /api/scrape endpoint from unauthorized triggers
# Generate one: openssl rand -hex 32
CRON_SECRET=your_secret_here

# ─── Optional ─────────────────────────────────────────────────────────────────
# Default ZIP code for inventory search (defaults to 30265 / Newnan GA)
DEFAULT_ZIP=30265

# Path to SQLite database file (defaults to ./data/tesla.db)
# DB_PATH=/var/data/tesla.db

# If you want the local scrape script to trigger your deployed site instead
# of writing to a local DB, set this:
# SITE_URL=https://teslaresaleindex.com
